# Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=

# Deepgram API key for voice transcription
DEEPGRAM_API_KEY=

# TickTick API token for task management MCP
TICKTICK_API_TOKEN=

# Optional TickTick API domain override (example for Dida365: https://api.dida365.com/open/v1)
TICKTICK_API_DOMAIN=

# Optional: override Codex CLI command (default: codex)
CODEX_CLI_COMMAND=codex

# Path to Obsidian vault directory
VAULT_PATH=./vault

# JSON array of Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=[123456789]
